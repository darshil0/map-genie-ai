# ============================================================================
# 16. EXCEPTIONS (Files/Folders TO INCLUDE despite above rules)
# ============================================================================

# Always include environment template (no secrets)
!.env.example

# Always include lock files for reproducibility (uncomment if using)
# !package-lock.json
# !yarn.lock
# !pnpm-lock.yaml

# Always include critical config templates
!.github/workflows/
!.vscode/settings.json.example
!.idea/runConfigurations.example/

# Always include essential documentation
!docs/

# ============================================================================
# GUIDELINES FOR MAINTENANCE
# ============================================================================

# When adding new patterns:
# 1. Add a comment explaining what's being ignored
# 2. Group by category (dependencies, logs, config, etc.)
# 3. Use wildcards for patterns (*.log, *.env)
# 4. Test with: git add . --dry-run
# 5. Verify critical files aren't ignored: git check-ignore <file>
#
# To audit what's actually ignored:
# git check-ignore -v <filename>
#
# To see what would be committed:
# git add . --dry-run
#
# To remove accidentally committed files:
# git rm --cached <file>
# git rm -r --cached <directory>
#
# For global ignores (affect all repos on your machine):
# Create ~/.gitignore_global and configure:
# git config --global core.excludesFile ~/.gitignore_global
