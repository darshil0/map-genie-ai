# Map-Genie Python Backend Configuration Template
# Copy to .env and fill in your values
# IMPORTANT: Never commit .env to version control!

# ============================================================================
# REQUIRED: Google Gemini API Configuration
# ============================================================================

# Your Google Gemini API key
# Get it from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here


# ============================================================================
# OPTIONAL: CORS & Security
# ============================================================================

# Comma-separated list of allowed origins for CORS
# Default: http://localhost:3000,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000


# ============================================================================
# OPTIONAL: API & Server Configuration
# ============================================================================

# Server port (default: 8000)
PORT=8000

# Node/deployment environment (default: development)
# Values: development, staging, production
NODE_ENV=development

# Request timeout in seconds (default: 30)
REQUEST_TIMEOUT_SECONDS=30

# Maximum chat history messages per request (default: 20)
MAX_HISTORY_MESSAGES=20


# ============================================================================
# OPTIONAL: Logging
# ============================================================================

# Logging level (default: INFO)
# Values: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO


# ============================================================================
# OPTIONAL: Monitoring & Observability
# ============================================================================

# Enable Prometheus metrics collection (default: false)
ENABLE_METRICS=false


# ============================================================================
# OPTIONAL: Third-Party Integrations
# ============================================================================

# Sentry error tracking (optional, requires Sentry account)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Slack webhook for notifications (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL


# ============================================================================
# OPTIONAL: Database (Future)
# ============================================================================

# For future persistence layer
# DATABASE_URL=postgresql://user:password@localhost:5432/map_genie
